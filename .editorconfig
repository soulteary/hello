root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_style = tab

[Makefile]
indent_style = tab

[*.{yml,yaml,md,json,toml}]
indent_style = space
indent_size = 2

[Dockerfile]
indent_style = space
indent_size = 4

# Animation assets are whitespace-significant ASCII art; leave them untouched.
[*.animation]
trim_trailing_whitespace = false
insert_final_newline = false
